<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MKS_V2.ViewModels"
             xmlns:core="using:MKS_V2.Core"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
             x:Class="MKS_V2.Views.LimitSettingsView"
             x:DataType="vm:LimitSettingsViewModel">

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="10">
            <TextBlock Text="Limits &amp; Homing" FontWeight="Bold" FontSize="16" />

            <!-- Limit Parameters Container -->
            <Border Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <StackPanel Spacing="10">
                    <TextBlock Text="Limit Parameters" FontWeight="SemiBold" />
                    
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Trigger Level:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,0,5" SelectedIndex="{Binding LimitTriggerLevel}">
                            <ComboBoxItem>Low</ComboBoxItem>
                            <ComboBoxItem>High</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Home Direction:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,0,5" SelectedIndex="{Binding HomeDirection}">
                            <ComboBoxItem>Reverse (CW)</ComboBoxItem>
                            <ComboBoxItem>Forward (CCW)</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Home Enable:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,0,5" SelectedIndex="{Binding HomeEnable}">
                            <ComboBoxItem>Disable</ComboBoxItem>
                            <ComboBoxItem>Enable</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Home Speed:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <NumericUpDown Grid.Row="3" Grid.Column="1" Minimum="1" Maximum="3000" Value="{Binding HomeSpeed}" HorizontalAlignment="Stretch"/>
                    </Grid>

                    <Button Content="Set Limit Parameters" Command="{Binding SaveLimitParametersCommand}" HorizontalAlignment="Stretch" />

                    <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
                        <Button Grid.Column="0" Content="Limit Home" Command="{Binding TriggerLimitHomeCommand}" HorizontalAlignment="Stretch" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="Direct Home" Command="{Binding TriggerDirectHomeCommand}" HorizontalAlignment="Stretch" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Single Turn Home Container -->
            <Border Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <StackPanel Spacing="10">
                    <TextBlock Text="Single Turn Home" FontWeight="SemiBold" />
                    
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Home Mode:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,0,5" SelectedIndex="{Binding SingleTurnHomeMode}">
                            <ComboBoxItem>Disable</ComboBoxItem>
                            <ComboBoxItem>DirMode</ComboBoxItem>
                            <ComboBoxItem>NearMode</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Set Zero:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,0,5" SelectedIndex="{Binding SingleTurnZeroSetting}">
                            <ComboBoxItem>Clear 0</ComboBoxItem>
                            <ComboBoxItem>Set 0</ComboBoxItem>
                            <ComboBoxItem>Hold 0</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Direction:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,0,5" SelectedIndex="{Binding SingleTurnHomeDirection}">
                            <ComboBoxItem>Reverse (CW)</ComboBoxItem>
                            <ComboBoxItem>Forward (CCW)</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Speed:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <NumericUpDown Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding SingleTurnHomeSpeed}" HorizontalAlignment="Stretch"/>
                    </Grid>

                    <Button Content="Trigger Single Turn Home" Command="{Binding TriggerSingleTurnHomeCommand}" HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
